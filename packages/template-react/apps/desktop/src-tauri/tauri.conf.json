{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "__PROJECT_NAME__",
  "version": "0.1.0",
  "identifier": "app.eikon.__PROJECT_NAME__",
  "build": {
    "beforeDevCommand": "pnpm --dir ../.. dev",
    "beforeBuildCommand": "pnpm --dir ../.. build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../../dist"
  },
  "app": {
    "windows": [
      {
        "title": "__PROJECT_NAME__",
        "width": 1280,
        "height": 800,
        "minWidth": 480,
        "minHeight": 320,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
