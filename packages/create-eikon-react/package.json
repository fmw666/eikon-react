{
  "name": "create-eikon-react",
  "version": "1.3.0",
  "description": "Scaffold an Eikon React app — React 19 + Tailwind v4 + animate-ui with feature-first architecture and AI-agent rules.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "create-eikon-react": "./dist/index.js"
  },
  "files": [
    "dist",
    "template",
    "template-snapshots",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ./scripts/sync-template.mjs && tsup",
    "start": "pnpm build && node ./dist/index.js",
    "dev": "tsup --watch",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "node ./scripts/e2e.mjs",
    "e2e:quick": "node ./scripts/e2e.mjs --quick",
    "smoke": "node ./scripts/smoke.mjs",
    "smoke:full": "node ./scripts/smoke.mjs --full",
    "sync-ui-snapshots": "node ./scripts/sync-ui-snapshots.mjs",
    "prepublishOnly": "pnpm typecheck && pnpm lint && pnpm test && pnpm e2e:quick && pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.13.1",
    "eslint": "^9.20.0",
    "tsup": "^8.3.6",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.23.0",
    "vitest": "^3.0.5"
  },
  "homepage": "https://github.com/fmw666/eikon-react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fmw666/eikon-react.git",
    "directory": "packages/create-eikon-react"
  },
  "bugs": {
    "url": "https://github.com/fmw666/eikon-react/issues"
  },
  "author": "Eikon",
  "engines": {
    "node": ">=20.10.0"
  },
  "keywords": [
    "react",
    "tailwindcss",
    "starter",
    "scaffold",
    "create-app",
    "ai",
    "feature-first"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
